meta {
  name: Process Transfer
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/pos/transfer
  body: json
  auth: bearer
}

auth:bearer {
  token: {{masterToken}}
}

body:json {
  {
    "sourceCard": "{{cardId}}",
    "destinationDocument": "{{destinationDocument}}",
    "destinationAccount": "{{destinationAccount}}",
    "amount": 2.50,
    "reference": "Bruno POS Test"
  }
}

script:post-response {
  bru.setEnvVar("transactionReference", res.body.data.reference);
}
