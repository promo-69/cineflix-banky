meta {
  name: Process Transaction
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/external/transactions
  body: json
  auth: bearer
}

auth:bearer {
  token: {{emitterToken}}
}

body:json {
  {
    "type": "transfer",
    "destinationDocument": "{{destinationDocument}}",
    "destinationAccount": "{{destinationAccount}}",
    "amount": 1.50,
    "reference": "Bruno External Test"
  }
}

script:post-response {
  bru.setEnvVar("transactionReference", res.body.data.reference);
}
